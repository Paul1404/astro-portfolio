---
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
import TechBadge from './TechBadge.astro';

interface Props {
	project: CollectionEntry<'projects'>;
}

const { data, id } = Astro.props.project;
const { title, description, img, img_alt, stack, repoUrl, liveUrl, status, icon } = data;

const statusLabel: Record<string, string> = { wip: 'In progress', archived: 'Archived' };
---

<article
	class="group relative flex flex-col overflow-hidden rounded-card border border-line bg-surface transition-all duration-200 hover:-translate-y-1 hover:border-line-strong hover:shadow-lg"
>
	<div class="relative aspect-[16/9] overflow-hidden border-b border-line bg-elevated">
		{
			img ? (
				<img
					src={img}
					alt={img_alt || title}
					loading="lazy"
					decoding="async"
					class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
				/>
			) : (
				<div class="flex h-full w-full items-center justify-center bg-[linear-gradient(135deg,var(--color-brand-tint),transparent)]">
					<Icon name={`lucide:${icon}`} class="h-12 w-12 text-brand" />
				</div>
			)
		}
		{
			status !== 'shipped' && (
				<span class="absolute right-3 top-3 rounded-full border border-line bg-surface/90 px-2.5 py-1 font-mono text-xs text-muted backdrop-blur">
					{statusLabel[status]}
				</span>
			)
		}
	</div>

	<div class="flex flex-1 flex-col gap-3 p-5">
		<h3 class="text-lg font-semibold text-ink">
			<a href={`/projects/${id}`} class="before:absolute before:inset-0 before:content-['']">
				{title}
			</a>
		</h3>
		<p class="line-clamp-3 flex-1 text-sm text-muted">{description}</p>

		{
			stack.length > 0 && (
				<div class="flex flex-wrap gap-1.5">
					{stack.slice(0, 4).map((s) => (
						<TechBadge label={s} />
					))}
				</div>
			)
		}

		{
			(repoUrl || liveUrl) && (
				<div class="relative z-10 mt-1 flex items-center gap-4 border-t border-line pt-3 text-sm">
					{repoUrl && (
						<a
							href={repoUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-1.5 text-subtle transition-colors hover:text-ink"
						>
							<Icon name="lucide:github" class="h-4 w-4" />
							Code
						</a>
					)}
					{liveUrl && (
						<a
							href={liveUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-1.5 text-subtle transition-colors hover:text-brand"
						>
							<Icon name="lucide:external-link" class="h-4 w-4" />
							Live
						</a>
					)}
				</div>
			)
		}
	</div>
</article>
