---
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();

const links = [
	{ label: t('nav.email'), href: 'mailto:contact@pd-portfolio.net', icon: 'lucide:mail' },
	{ label: t('nav.github'), href: 'https://github.com/Paul1404', icon: 'lucide:github' },
];
---

<footer class="mt-24 border-t border-line">
	<div
		class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 py-10 text-sm text-subtle sm:flex-row"
	>
		<div class="flex flex-col items-center gap-1 sm:items-start">
			<p>&copy; {currentYear} Paul Dresch</p>
			<p>{t('footer.builtWith')}</p>
		</div>
		<div class="flex items-center gap-4">
			{
				links.map(({ label, href, icon }) => (
					<a
						href={href}
						target={href.startsWith('http') ? '_blank' : undefined}
						rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
						class="inline-flex items-center gap-1.5 transition-colors hover:text-ink"
					>
						<Icon name={icon} class="h-4 w-4" />
						{label}
					</a>
				))
			}
			<a
				href={`${localizePath('/privacy-policy/', lang)}#impressum`}
				class="transition-colors hover:text-ink"
			>
				{t('footer.legal')}
			</a>
		</div>
	</div>
</footer>
