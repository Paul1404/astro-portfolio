---
interface Props {
	title: string;
	tagline?: string;
	eyebrow?: string;
	align?: 'start' | 'center';
}

const { align = 'center', tagline, title, eyebrow } = Astro.props;
const center = align === 'center';
---

<div class:list={['flex flex-col gap-4', center && 'items-center text-center']}>
	<div class:list={['flex flex-col gap-3', center && 'items-center']}>
		{
			eyebrow && (
				<span class="font-mono text-sm uppercase tracking-[0.2em] text-brand">
					{eyebrow}
				</span>
			)
		}
		<h1 class="text-4xl font-semibold sm:text-5xl">{title}</h1>
		{
			tagline && (
				<p class:list={['max-w-2xl text-lg text-muted', center && 'mx-auto']}>{tagline}</p>
			)
		}
	</div>
	<slot />
</div>
