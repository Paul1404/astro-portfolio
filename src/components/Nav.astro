---
import { Icon } from 'astro-icon/components';
import ThemeToggle from './ThemeToggle.astro';
import LangSwitcher from './LangSwitcher.astro';
import { getLangFromUrl, useTranslations, localizePath, stripLangFromPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const textLinks = [
	{ label: t('nav.home'), href: localizePath('/', lang) },
	{ label: t('nav.projects'), href: localizePath('/projects/', lang) },
	{ label: t('nav.about'), href: localizePath('/about/', lang) },
	{ label: t('nav.terminal'), href: localizePath('/terminal/', lang) },
];

const iconLinks = [
	{ label: t('nav.email'), href: 'mailto:contact@pd-portfolio.net', icon: 'lucide:mail' },
	{ label: t('nav.github'), href: 'https://github.com/Paul1404', icon: 'lucide:github' },
];

const path = stripLangFromPath(Astro.url.pathname);
const isActive = (href: string) => {
	const target = stripLangFromPath(href);
	return target === '/' ? path === '/' : path.startsWith(target);
};
---

<header
	data-nav
	class="sticky top-0 z-50 border-b border-transparent transition-all duration-300 [&.is-scrolled]:border-line [&.is-scrolled]:bg-canvas/80 [&.is-scrolled]:backdrop-blur-md [&.is-scrolled]:shadow-[0_8px_30px_-20px_rgba(0,0,0,0.4)]"
>
	<nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
		<a href={localizePath('/', lang)} class="font-display text-lg font-bold tracking-tight">
			<span class="text-gradient">Paul Dresch</span>
		</a>

		<!-- Desktop -->
		<div class="hidden items-center gap-1 md:flex">
			{
				textLinks.map(({ label, href }) => (
					<a
						href={href}
						aria-current={isActive(href) ? 'page' : undefined}
						class:list={[
							'rounded-full px-3 py-1.5 text-sm transition-colors',
							isActive(href) ? 'bg-brand-tint text-ink' : 'text-muted hover:text-ink',
						]}
					>
						{label}
					</a>
				))
			}
			<span class="mx-2 h-5 w-px bg-line"></span>
			{
				iconLinks.map(({ href, icon, label }) => (
					<a
						href={href}
						target={href.startsWith('http') ? '_blank' : undefined}
						rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
						class="inline-flex h-9 w-9 items-center justify-center rounded-full text-muted transition-colors hover:text-ink"
					>
						<span class="sr-only">{label}</span>
						<Icon name={icon} class="h-4 w-4" />
					</a>
				))
			}
			<LangSwitcher />
			<ThemeToggle />
		</div>

		<!-- Mobile -->
		<details class="group relative md:hidden">
			<summary
				class="flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-full border border-line text-muted [&::-webkit-details-marker]:hidden"
			>
				<span class="sr-only">{t('a11y.menu')}</span>
				<Icon name="lucide:menu" class="h-5 w-5 group-open:hidden" />
				<Icon name="lucide:x" class="hidden h-5 w-5 group-open:block" />
			</summary>
			<div class="absolute right-0 mt-3 w-56 rounded-card border border-line bg-surface p-2 shadow-lg">
				{
					textLinks.map(({ label, href }) => (
						<a
							href={href}
							class:list={[
								'block rounded-lg px-3 py-2 text-sm transition-colors',
								isActive(href)
									? 'bg-brand-tint text-ink'
									: 'text-muted hover:bg-elevated hover:text-ink',
							]}
						>
							{label}
						</a>
					))
				}
				<div class="my-2 h-px bg-line"></div>
				<div class="flex items-center justify-between px-2">
					<div class="flex items-center gap-1">
						{
							iconLinks.map(({ href, icon, label }) => (
								<a
									href={href}
									target={href.startsWith('http') ? '_blank' : undefined}
									rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
									class="inline-flex h-9 w-9 items-center justify-center rounded-full text-muted transition-colors hover:text-ink"
								>
									<span class="sr-only">{label}</span>
									<Icon name={icon} class="h-4 w-4" />
								</a>
							))
						}
					</div>
					<div class="flex items-center gap-2">
						<LangSwitcher />
						<ThemeToggle />
					</div>
				</div>
			</div>
		</details>
	</nav>
</header>
