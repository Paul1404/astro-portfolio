---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';

const skills = [
	{
		icon: 'lucide:server',
		title: 'Systems engineering',
		body: 'A full 42U homelab rack with Dell servers, Brocade and Arista switches, and enterprise virtualization. It is my proving ground for production-grade infrastructure.',
	},
	{
		icon: 'lucide:box',
		title: 'Virtualization and containers',
		body: 'VMware vSphere with clustering and vSAN ESA, Proxmox, and 30 plus Docker containers managed through Portainer EE.',
	},
	{
		icon: 'lucide:terminal',
		title: 'Linux and automation',
		body: 'Red Hat Certified System Administrator (EX200). I manage RHEL with Satellite and automate with Ansible, Bash, and Python.',
	},
	{
		icon: 'lucide:network',
		title: 'Networking',
		body: 'I design and run 10G plus networks with datacenter-grade switches, with a focus on reliable, high-performance setups.',
	},
];
---

<BaseLayout title="About | Paul Dresch" description="Systems engineer who builds and ships real software.">
	<div class="mx-auto max-w-6xl px-6 pt-20 sm:pt-28">
		<Hero
			eyebrow="About"
			title="Systems engineer who ships software"
			tagline="I spend my days close to real infrastructure, and I turn that into tools that solve actual problems. Here is the short version."
			align="start"
		/>
	</div>

	<div class="mx-auto mt-12 grid max-w-6xl gap-10 px-6 lg:grid-cols-[1.4fr_1fr]">
		<div class="prose prose-lg max-w-none dark:prose-invert prose-headings:font-display prose-a:text-brand">
			<p>
				I am a systems engineer with a deep interest in Linux, virtualization, and
				networking. My homelab is not a hobby corner. It is a full rack of enterprise
				hardware where I run the same kind of infrastructure you would find in a
				datacenter, then use it to build and test the software I ship.
			</p>
			<p>
				Most of what I make comes straight out of a real need: a club that needed its
				member letters automated, a mail server that needed proper monitoring, a pile of
				Dependabot pull requests that needed taming. I like the unglamorous problems,
				and I like solving them in a way that other people can use.
			</p>
		</div>
		<div class="overflow-hidden rounded-card border border-line">
			<img src="/assets/blog-about.jpg" alt="Paul's homelab rack" class="h-full w-full object-cover" />
		</div>
	</div>

	<div class="mx-auto mt-16 max-w-6xl px-6">
		<h2 class="text-2xl font-semibold sm:text-3xl">What I work with</h2>
		<div class="mt-8 grid gap-5 sm:grid-cols-2">
			{
				skills.map((s) => (
					<div class="rounded-card border border-line bg-surface p-6">
						<div class="flex h-11 w-11 items-center justify-center rounded-lg bg-brand-tint text-brand">
							<Icon name={s.icon} class="h-5 w-5" />
						</div>
						<h3 class="mt-4 text-lg font-semibold text-ink">{s.title}</h3>
						<p class="mt-2 text-sm text-muted">{s.body}</p>
					</div>
				))
			}
		</div>
	</div>

	<div class="mt-24">
		<ContactCTA />
	</div>
</BaseLayout>
