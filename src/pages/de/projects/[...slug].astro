---
import ProjectDetailPage from '../../../components/pages/ProjectDetailPage.astro';
import { getProjects, slugOf } from '../../../lib/projects';

export async function getStaticPaths() {
	const projects = await getProjects('de');
	return projects.map((entry) => ({
		params: { slug: slugOf(entry) },
		props: { entry },
	}));
}

const { entry } = Astro.props;
---

<ProjectDetailPage entry={entry} />
