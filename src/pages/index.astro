---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ContactCTA from '../components/ContactCTA.astro';
import CallToAction from '../components/CallToAction.astro';

const allProjects = (await getCollection('projects')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const featured = allProjects.filter((p) => p.data.featured);
const projects = (featured.length ? featured : allProjects).slice(0, 6);

const focus = ['Linux', 'Virtualization', 'Networking', 'Containers', 'Automation'];
---

<BaseLayout
	title="Paul Dresch | Systems engineer and software builder"
	description="Systems engineer who builds and ships real software. Self-hosted tools, automation, and infrastructure projects."
>
	<!-- Hero -->
	<section class="mx-auto max-w-6xl px-6 pb-16 pt-20 sm:pt-28">
		<p class="font-mono text-sm uppercase tracking-[0.2em] text-brand">
			Systems engineer
		</p>
		<h1 class="mt-4 max-w-4xl text-4xl font-semibold leading-[1.1] sm:text-6xl">
			I build and ship <span class="text-gradient">real software</span>, not just slide decks.
		</h1>
		<p class="mt-6 max-w-2xl text-lg text-muted">
			I run a 42U homelab and turn that hands-on infrastructure work into tools people
			actually use: self-hosted apps, automation, and the boring plumbing that keeps
			systems running.
		</p>
		<div class="mt-8 flex flex-wrap gap-3">
			<CallToAction href="/projects/">
				View projects
				<Icon name="lucide:arrow-right" class="h-4 w-4" />
			</CallToAction>
			<CallToAction href="https://github.com/Paul1404" variant="outline" external>
				<Icon name="lucide:github" class="h-4 w-4" />
				GitHub
			</CallToAction>
			<CallToAction href="mailto:contact@pd-portfolio.net" variant="ghost">
				<Icon name="lucide:mail" class="h-4 w-4" />
				Contact
			</CallToAction>
		</div>
		<div class="mt-10 flex flex-wrap gap-2">
			{
				focus.map((f) => (
					<span class="rounded-full border border-line bg-surface px-3 py-1 font-mono text-xs text-muted">
						{f}
					</span>
				))
			}
		</div>
	</section>

	<!-- Featured projects -->
	<Section eyebrow="Selected work" title="Things I have built" class="py-8">
		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{projects.map((project) => <ProjectCard project={project} />)}
		</div>
		<div class="mt-10 flex justify-center">
			<CallToAction href="/projects/" variant="outline">
				See all projects
				<Icon name="lucide:arrow-right" class="h-4 w-4" />
			</CallToAction>
		</div>
	</Section>

	<div class="mt-24">
		<ContactCTA />
	</div>
</BaseLayout>
